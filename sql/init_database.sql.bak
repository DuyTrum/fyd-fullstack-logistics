-- ====================================================================
-- SEED PRODUCTS (66 rows)
-- ====================================================================
INSERT INTO `products` (`id`, `sku`, `name`, `slug`, `category_id`, `brand_id`, `base_price`, `sale_price`, `description`, `short_description`, `material`, `is_featured`, `is_new`, `status`, `view_count`, `sold_count`, `created_at`, `updated_at`) VALUES
(201, '553558-048', 'Air Jordan 1 Low', 'nike-air-jordan-1-low-553558-048', 11, 5, 3239000.00, NULL, 'Lấy cảm hứng từ phiên bản gốc ra mắt năm 1985, Air Jordan 1 Low mang đến vẻ ngoài cổ điển, gọn gàng, quen thuộc nhưng luôn mới mẻ. Với thiết kế mang tính biểu tượng kết hợp hoàn hảo với bất kỳ kiểu giày nào, những đôi giày này đảm bảo bạn sẽ luôn đi đúng hướng.

Đặc điểm nổi bật:
- Bộ phận Air-Sole đóng gói cung cấp đệm nhẹ.
- Da thật ở phía trên mang lại độ bền và vẻ ngoài cao cấp.
- Đế ngoài bằng cao su đặc tăng cường độ bám trên nhiều bề mặt.', 'Giày nam', 'Lưới, Da Nhân Tạo, Cao Su', 1, 1, 'ACTIVE', 301, 31, '2026-06-23 04:41:17', '2026-06-23 07:01:06'),
(202, 'II7045-900', 'Nike Gato LV8', 'nike-nike-gato-lv8-ii7045-900', 11, 5, 3519000.00, NULL, 'Kỷ niệm bóng đá trên sân khấu lớn nhất ở Gato thân yêu. Nổi tiếng với trò chơi trong nhà, phiên bản đường phố này có màu sắc giống với ''Green Blur''. Chất liệu vải thoáng mát và da nguyên hạt kết hợp với nhau để bổ sung thêm sự phù hợp cho ngày thi đấu của bạn.', 'Giày nam', 'Lưới, Da Nhân Tạo, Cao Su', 1, 0, 'ACTIVE', 538, 46, '2026-06-23 04:41:17', '2026-06-23 07:01:06'),
(203, 'IO9316-001', 'Nike Air Max 90 G', 'nike-nike-air-max-90-g-io9316-001', 11, 5, 4999000.00, NULL, 'Học chuyên ngành ở Hamptons không phải là ngày nghỉ. Màu sắc và đồ họa hàng hải gắn liền chiếc Air Max 90 này với giải đấu golf hấp dẫn nhất mùa hè. Đúng như biểu tượng ban đầu, phiên bản này có các chi tiết dành cho chơi gôn như lực kéo tích hợp và lớp phủ mỏng giúp ngăn nước.', 'Giày chơi gôn', 'Lưới, Da Nhân Tạo, Cao Su', 1, 1, 'ACTIVE', 455, 53, '2026-06-23 04:41:17', '2026-06-23 07:01:06'),
(204, 'HV1488-300', 'Nike Vapor 12 Hypersmash', 'nike-nike-vapor-12-hypersmash-hv1488-300', 11, 5, 5279000.00, NULL, 'Hardcourt là bề mặt ổn định nhất, nhưng nó cũng là bề mặt không thể tha thứ nhất. Các vật liệu được cải tiến ở mặt trên và đế ngoài mang lại độ bám và độ bền để chơi ở tốc độ tối đa trong thời gian dài hơn. Đệm Air Zoom giúp mặt sân mềm mại hơn trong khi các chi tiết thiết kế lấy cảm hứng từ giày bóng rổ Hyperdunk ''08 giúp bạn có cảm giác như mình đã chiến thắng ngay cả trước khi bước vào sân.', 'Giày tennis sân cứng nam', 'Lưới, Da Nhân Tạo, Cao Su', 1, 1, 'ACTIVE', 105, 5, '2026-06-23 04:41:17', '2026-06-23 07:01:06'),
(205, 'HF2882-303', 'Sabrina 3 EP', 'nike-sabrina-3-ep-hf2882-303', 11, 5, 3829000.00, NULL, 'Việc theo đuổi sự xuất sắc của Sabrina Ionescu đòi hỏi một chiếc giày có thể theo kịp cả đạo đức làm việc và ý chí chiến thắng của cô. Hãy bước vào Sabrina 3. Phần trên nhẹ, an toàn giúp cô được hỗ trợ bằng dây cáp, cho phép cô di chuyển, trượt và lùi lại một cách tự tin. Với đế ngoài bằng cao su siêu bền, phiên bản này mang lại cho bạn lực kéo trên sân ngoài trời.', 'Giày bóng rổ', 'Lưới, Da Nhân Tạo, Cao Su', 1, 1, 'ACTIVE', 257, 13, '2026-06-23 04:41:17', '2026-06-23 07:01:06'),
(206, 'IR3980-100', 'Nike Zoom Vapor 12 PRM', 'nike-nike-zoom-vapor-12-prm-ir3980-100', 11, 5, 4999000.00, NULL, 'Hãy để trò chơi của bạn thu hút sự chú ý của những người giỏi nhất trong môn thể thao này với Vapor 12 đặc biệt này. Nhẹ hơn và nhạy hơn Vapor 11, nó giúp bạn tiếp cận mọi quả bóng với tốc độ chóng mặt. Màu sắc phiên bản đặc biệt này kết hợp vẻ ngoài truyền thống của giải đấu với các điểm nhấn và lớp hoàn thiện nhằm tôn vinh bề mặt ban đầu của môn quần vợt.', 'Giày tennis sân cứng nam', 'Lưới, Da Nhân Tạo, Cao Su', 1, 1, 'ACTIVE', 177, 16, '2026-06-23 04:41:17', '2026-06-23 07:01:06'),
(207, 'IO9556-600', 'Nike Air Max Plus 7 Premium', 'nike-nike-air-max-plus-7-premium-io9556-600', 11, 5, 5589000.00, NULL, 'Hãy để thái độ của bạn được nâng cao với Air Max Plus. Lớp phủ đặc trưng của nó gợn sóng trên giày tăng thêm sức nóng cho vẻ ngoài của bạn trong khi lớp lưới thoáng mát giúp bạn mát mẻ. Và phần đệm nhìn thấy được giúp bạn thể hiện phong cách thách thức của mình một cách thoải mái.

Đặc điểm nổi bật:
- Mặt trên bằng lưới với các điểm nhấn bằng da tổng hợp bền và thoáng khí.
- Vòm giữa bàn chân mang lại cảm giác hỗ trợ.
- Đơn vị Nike Air cung cấp đệm nhẹ.
- Đế ngoài cao su mang lại cho bạn lực kéo bền bỉ.', 'Giày nam', 'Lưới, Da Nhân Tạo, Cao Su', 1, 0, 'ACTIVE', 150, 13, '2026-06-23 04:41:17', '2026-06-23 07:01:06'),
(208, 'HV8113-103', 'ACG Zegama Trail', 'nike-acg-zegama-trail-hv8113-103', 11, 5, 4999000.00, NULL, 'Một vận động viên chạy đường mòn đáng tin cậy sẽ có được vị trí xứng đáng trong ACG. Và nó đi kèm với một số nâng cấp trong mọi điều kiện. ACG Zegama nhẹ và siêu đệm kết hợp lực kéo bám chắc và nhiều không gian hơn cho ngón chân của bạn để mang lại sự thoải mái và khả năng kiểm soát lâu dài trên địa hình gồ ghề, địa hình. Leo dốc, lùi bằng kẹp tóc, lao dốc — Zegama được chế tạo để giải quyết tất cả. Bạn có phải?', 'Giày chạy địa hình nam', 'Lưới, Da Nhân Tạo, Cao Su', 1, 0, 'ACTIVE', 443, 36, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(209, 'IR2014-012', 'Air Jordan 1 Low SE Craft', 'nike-air-jordan-1-low-se-craft-ir2014-012', 11, 5, 4109000.00, NULL, 'Đôi giày màu trung tính yêu thích mới của bạn vừa được ra mắt và nó mang lại cảm giác cao cấp như vẻ ngoài của nó. Chiếc AJ1 này kết hợp da, da lộn và vải ở phía trên để tạo ra vẻ ngoài có chiều sâu.

Đặc điểm nổi bật:
- Da và vải ở phía trên mang lại độ bền và cấu trúc.
- Bộ Nike Air-Sole cung cấp đệm nhẹ.
- Cao su ở đế ngoài mang lại cho bạn lực kéo trên nhiều bề mặt khác nhau.', 'Giày nam', 'Lưới, Da Nhân Tạo, Cao Su', 0, 0, 'ACTIVE', 402, 40, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(210, 'CD6404-106', 'Nike P-6000', 'nike-nike-p-6000-cd6404-106', 11, 5, 2929000.00, NULL, 'Nike P-6000 dựa trên Nike Air Pegasus 2006, mang đến cho bạn sự kết hợp giữa phong cách mang tính biểu tượng, thoáng khí, thoải mái và gợi lên cảm giác đầu những năm 2000.', 'Đôi giày', 'Lưới, Da Nhân Tạo, Cao Su', 0, 0, 'ACTIVE', 119, 20, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(211, 'IR0952-100', 'Nike Air Force 1 ''07 LV8', 'nike-nike-air-force-1-07-lv8-ir0952-100', 11, 5, 3519000.00, NULL, 'Thoải mái, bền bỉ và trường tồn với thời gian - đó là lý do số một. Kiểu dáng cổ điển của thập niên 80 kết hợp với các chi tiết táo bạo tạo nên phong cách phù hợp dù bạn đang ở trên sân hay đang di chuyển.

Đặc điểm nổi bật:
- Đơn vị Nike Air cung cấp đệm nhẹ.
- Đế ngoài bằng cao su với các vòng tròn xoay truyền thống mang lại lực kéo và độ bền.', 'Giày nam', 'Lưới, Da Nhân Tạo, Cao Su', 0, 0, 'ACTIVE', 398, 53, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(212, 'HJ5996-005', 'Nike Air Max 95 Big Bubble', 'nike-nike-air-max-95-big-bubble-hj5996-005', 11, 5, 4999000.00, NULL, 'Air Max 95 ban đầu lấy cảm hứng từ giải phẫu con người, dẫn đến thiết kế lượn sóng đặc biệt. Phiên bản này kết hợp các chất liệu hỗn hợp và đệm Max Air có thể nhìn thấy được để mang lại vẻ ngoài nhiều lớp với sự thoải mái không thể tin được.

Đặc điểm nổi bật:
- Phần thân giày lấy cảm hứng từ cơ thể con người—đế giữa tượng trưng cho cột sống, các tấm chia độ là các cơ và dây buộc là sườn của giày.
- Chất liệu dệt và da tổng hợp tạo nên vẻ ngoài nhiều lớp có độ bền lâu dài.
- Đệm Max Air có thể nhìn thấy mang lại khả năng đệm nhẹ.
- Các rãnh linh hoạt ở đế giữa/đế ngoài cho phép bạn di chuyển tự do.', 'Giày nữ', 'Lưới, Da Nhân Tạo, Cao Su', 0, 0, 'ACTIVE', 252, 32, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(213, 'IM8814-001', 'Nike Air Max Phenomena', 'nike-nike-air-max-phenomena-im8814-001', 11, 5, 4409000.00, NULL, 'Hiện tượng Air Max mô phỏng lại Air Max SNDR như một đôi giày lười kiểu dáng đẹp. Chất liệu cao cấp kết hợp với đệm Max Air giúp bạn thoải mái khi đeo cả ngày và đủ phong cách để đeo cả đêm.

Đặc điểm nổi bật:
- Da thật và da tổng hợp mang lại độ bền và cấu trúc.
- Sang trọng và thoải mái, đệm Max Air có mức hỗ trợ vừa phải.
- Đế ngoài bằng cao su tăng độ bền và độ bám.', 'Giày nữ', 'Lưới, Da Nhân Tạo, Cao Su', 0, 1, 'ACTIVE', 441, 8, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(214, 'IO7702-001', 'Air Jordan Mule SE', 'nike-air-jordan-mule-se-io7702-001', 11, 5, 4699000.00, NULL, 'The Air Jordan Mule combines a classic loafer upper, a soft foam platform and heritage Jordan style. Những gì bạn nhận được là một đôi giày kiểu dáng đẹp và thoải mái, đủ chắc chắn để mang hàng ngày. Các thành bên bằng cao su mang đến cho bạn vẻ ngoài chắc chắn trong khi phần cứng lấy cảm hứng từ sự quyến rũ sẽ tạo thêm nét độc đáo.

Đặc điểm nổi bật:
- Thân giày bằng da thật cho cảm giác cao cấp và bền bỉ.
- Nền xốp hoạt động với các thành bên bằng cao su để tạo vẻ chắc chắn mà không tăng thêm trọng lượng.
- Cấu trúc trượt giúp bạn ra khỏi cửa nhanh chóng.
- Công nghệ Nike Air hấp thụ lực tác động giúp giảm chấn theo từng bước đi.', 'Giày nữ', 'Lưới, Da Nhân Tạo, Cao Su', 0, 1, 'ACTIVE', 134, 21, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(215, 'IQ8102-101', 'Nike Vomero Premium', 'nike-nike-vomero-premium-iq8102-101', 11, 5, 6459000.00, NULL, 'Tận dụng khả năng giảm chấn tối đa ở Vomero Premium. Hai bộ Air Zoom tăng cường năng lượng kết hợp với một lượng lớn bọt ZoomX phản ứng nhanh để mang lại cho bạn độ nảy và sự thoải mái tối đa. Đây là chuyến đi êm ái và thoải mái nhất của chúng tôi được thiết kế để khai thác tiềm năng quãng đường của bạn.', 'Giày chạy bộ đường trường nữ', 'Lưới, Da Nhân Tạo, Cao Su', 0, 1, 'ACTIVE', 96, 43, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(216, 'HV8121-001', 'Nike ACG Pegasus Trail', 'nike-nike-acg-pegasus-trail-hv8121-001', 11, 5, 4109000.00, NULL, 'Một đôi giày được thiết kế dành cho những con đường mòn với khả năng phản hồi nhanh chóng mà bạn biết trên đường đi. Đó chính là mục đích của Đường mòn ACG Pegasus—chạy hàng dặm ngắm cảnh với đệm thoải mái. Chúng tôi đảm bảo rằng nó có độ bám cần thiết để bám đường trên địa hình ẩm ướt. Và sự phù hợp? Bàn chân trước rộng hơn giúp ngón chân của bạn có thêm không gian ngọ nguậy.', 'Giày chạy địa hình dành cho nữ', 'Lưới, Da Nhân Tạo, Cao Su', 0, 1, 'ACTIVE', 443, 10, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(217, 'IB1025-341', 'NikeCourt Slam', 'nike-nikecourt-slam-ib1025-341', 5, 5, 2399000.00, NULL, 'Bề mặt đầu tiên trong trò chơi và vẫn đang diễn ra mạnh mẽ. Là lời ca ngợi sân cỏ, chiếc áo này kết hợp công nghệ thấm mồ hôi tiên tiến và vải dệt kim co giãn bốn chiều để giúp các vận động viên quần vợt hàng đầu của chúng tôi thi đấu hết mình trên sân cỏ truyền thống.

Đặc điểm nổi bật:
- Nike Dri-FIT ADV nâng cấp công nghệ thấm mồ hôi của chúng tôi với khả năng làm mát tiên tiến và vùng thoáng khí giúp bạn luôn khô ráo và thoải mái.
- Thiết kế đường may được cập nhật giúp giải phóng vai của bạn để bạn có thể giao bóng và đánh bóng với đầy đủ các chuyển động—bất kể bạn thi đấu trên bề mặt nào.
- Viền đuôi thả cung cấp độ che phủ nhất quán bất kể vị trí của bạn.
- Đường khâu gấp giúp viền áo hoàn thiện gọn gàng, không bị rối mắt.', 'Áo polo quần vợt Dri-FIT ADV cho nam', 'Polyester, Cotton, Spandex', 0, 1, 'ACTIVE', 396, 43, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(218, 'IF3900-741', 'Jordan', 'nike-jordan-if3900-741', 5, 5, 2299000.00, NULL, 'Phong cách sẵn sàng được phối lại cho đường phố. Được làm bằng vải dệt kim nhẹ, chiếc áo thủ môn này lấy cảm hứng từ những chiếc áo sơ mi cổ điển để mang đến cho bạn vẻ ngoài táo bạo, lấy cảm hứng từ thể thao.', 'Áo thủ môn nam', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 537, 26, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(219, 'IH8565-045', 'LeBron ''Masked Menace''', 'nike-lebron-masked-menace-ih8565-045', 5, 5, 1119000.00, NULL, 'LeBron đeo mặt nạ là một thế lực tự nhiên. Hãy tôn vinh màn trình diễn xuất sắc của anh ấy với chiếc áo phông thoải mái này, có vai trễ, tay áo dài hơn và độ rộng rãi vừa vặn trên cơ thể và hông để mang lại vẻ ngoài thoải mái và giản dị. Vải cotton có trọng lượng trung bình tạo cảm giác mềm mại và có độ rủ nhẹ.', 'Áo thun bóng rổ nam', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 317, 51, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(220, 'IH8559-045', 'LeBron ''Motor King''', 'nike-lebron-motor-king-ih8559-045', 5, 5, 1119000.00, NULL, 'Bước đột phá trong trận playoff của LeBron đến ở Motor City, với một trong những khoảnh khắc đáng nhớ nhất trong truyền thuyết sau mùa giải. Với loạt trận hòa 2–2, Nhà vua ghi được 48 điểm, bao gồm 25 điểm cuối cùng của Cavs và 29 trong số 30 điểm cuối cùng của họ. Chiến thắng kép trong hiệp phụ không chỉ đưa Cleveland lần đầu tiên góp mặt trong trận Chung kết mà còn cho thế giới bóng rổ biết Nhà vua đã đến. Chiếc áo phông Max90 này tôn vinh tầm quan trọng của trò chơi và loạt trò chơi đó.

Đặc điểm nổi bật:
- Áo thun Max90 có kiểu dáng vừa vặn thoải mái với vai trễ và tay áo dài hơn.
- Chất liệu vải cotton dày vừa phải tạo cảm giác mềm mại và có độ rủ nhẹ.', 'Áo thun bóng rổ nam Nike', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 195, 43, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(221, 'IF2923-699', 'Jordan Sport', 'nike-jordan-sport-if2923-699', 5, 5, 3219000.00, NULL, 'Chiếc áo polo này được thiết kế dành cho các mắt xích. Chất liệu vải dệt kim co giãn giúp bạn luôn tươi mới qua tất cả 18 lỗ. Và cái nhìn? Đó là phong cách Jordan xuyên suốt.', 'Áo polo Jacquard chơi gôn cho nam', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 397, 25, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(222, 'IR6452-317', 'Nike Sportswear', 'nike-nike-sportswear-ir6452-317', 5, 5, 1019000.00, NULL, 'Chiếc áo phông này bày tỏ lòng tôn kính đối với lịch sử của chúng tôi thông qua logo. Chất liệu cotton có trọng lượng trung bình tạo cảm giác mềm mại và có cấu trúc nhẹ mang lại sự thoải mái, bền bỉ hàng ngày.', 'Áo thun nam', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 393, 21, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(223, 'IH8578-045', 'LeBron ''Hurt Feelings''', 'nike-lebron-hurt-feelings-ih8578-045', 5, 5, 1119000.00, NULL, 'Khi một xạ thủ đối phương nói rằng LeBron không thể xử lý một cuộc nói chuyện rác rưởi nhỏ vào năm 2016, với tỷ số 3-1, điều đó đã khơi dậy điều gì đó bên trong King James. Phần còn lại là lịch sử. LeBron đã dẫn dắt Cavs từ bờ vực bị loại đến chức vô địch, nổi bật bằng trận đấu được cho là lớn nhất trong sự nghiệp của Bron — một trận đấu bất ngờ vào cuối Game 7 hòa
đã làm thay đổi làn sóng của cuộc thi. Chiếc áo phông này chào mừng khoảnh khắc lịch sử đó, khi Cavs trở thành đội duy nhất trong lịch sử giải đấu vượt qua mức thâm hụt 3–1 để giành chức vô địch đầu tiên và duy nhất của họ.

Đặc điểm nổi bật:
- Chất liệu vải cotton dày vừa phải tạo cảm giác mềm mại và có độ rủ nhẹ.
- Áo thun Max90 có kiểu dáng vừa vặn thoải mái với vai trễ và tay áo dài hơn.', 'Áo thun bóng rổ nam Nike', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 199, 36, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(224, 'IF1898-077', 'Jordan Flight Club Jersey', 'nike-jordan-flight-club-if1898-077', 5, 5, 2859000.00, NULL, 'Mềm mại, nhẹ và chỉ có một chút ánh sáng—chiếc áo jersey rộng rãi này mang lại điều đó. Thương hiệu Jordan cho họ biết bạn đại diện cho ai.', 'Áo sơ mi nam', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 530, 42, '2026-06-23 04:41:18', '2026-06-24 02:33:21'),
(225, 'II0777-486', 'Nike Tartan', 'nike-nike-tartan-ii0777-486', 7, 5, 3219000.00, NULL, 'Chúng tôi đã tìm đến kho tiền của mình để mang về mẫu áo len kẻ sọc chỉ có ở Nike cho chiếc áo len vừa vặn thoải mái này. Để tôn vinh tình yêu của chúng ta với môn chơi gôn và nơi khai sinh ra môn thể thao này, họa tiết di sản này kết hợp với vải sợi jumper để tạo vẻ ngoài giúp tăng thêm sự ấm áp nhanh chóng và phong cách vượt thời gian cho vòng đấu của bạn.

Đặc điểm nổi bật:
- Chi tiết đan gân ở cổ tay áo và viền dưới mang lại cảm giác sạch sẽ, thoải mái.
- Chất liệu vải dệt kim có trọng lượng vừa phải mang lại cảm giác ấm áp linh hoạt, sẵn sàng cho thời tiết mát mẻ hơn.', 'Áo khoác golf rộng rãi cho nam', 'Polyester, Cotton, Spandex', 0, 1, 'ACTIVE', 292, 30, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(226, 'II5318-040', 'Jordan Brooklyn', 'nike-jordan-brooklyn-ii5318-040', 7, 5, 2039000.00, NULL, 'Cảm thấy ớn lạnh? Hãy khoác lên mình chiếc áo khoác vỏ nhẹ, rộng rãi này. Nó được làm bằng nylon mịn để mang lại cảm giác ấm áp nhẹ.', 'Áo khoác vỏ nhẹ cho nam', 'Polyester, Cotton, Spandex', 0, 0, 'ACTIVE', 105, 19, '2026-06-23 04:41:18', '2026-06-23 07:01:06'),
(227, 'HM9965-819', 'Nike Varsity Elite Backpack', 'nike-nike-varsity-elite-hm9965-819', 14, 5, 2299000.00, NULL, 'Ba lô Varsity Elite chứa mọi thứ bạn cần. Một ngăn chính lớn có thể đựng vừa một quả bóng rổ cỡ lớn. Một túi phía trước bên ngoài cho phép lấy nhanh các vật dụng nhỏ và một túi phía dưới giúp tách biệt quần áo đẫm mồ hôi và giày bẩn. Tay áo xe đẩy cho phép bạn gắn nó vào hành lý khi đi chơi những trận đấu trên sân khách.

Đặc điểm nổi bật:
- Dây đeo vai có công nghệ Air Max giúp tăng cường sự thoải mái.
- Túi zip phía trên được lót sang trọng để bảo vệ đồ công nghệ và đồ có giá trị.
- Ngăn đựng laptop bên trong vừa vặn với laptop 40,5cm (xấp xỉ).', 'Ba lô (32L)', 'Nylon Chống Nước, Polyester', 0, 0, 'ACTIVE', 544, 10, '2026-06-23 04:41:18', '2026-06-24 02:33:17'),
(229, 'FN3895-010', 'Nike Club', 'nike-nike-club-fn3895-010', 6, 5, 1279000.00, NULL, 'Áo thun polo thể thao Nike Club được thiết kế với chất liệu Dri-FIT thoáng khí, giúp thấm hút mồ hôi cực tốt và giữ cho bạn luôn khô ráo, dễ chịu trên sân tập cũng như trong các hoạt động hàng ngày. Kiểu dáng polo cổ điển thanh lịch phù hợp cho nhiều dịp khác nhau.', 'Men''s Short-Sleeve Polo', 'Polyester & Spandex (Dri-FIT)', 0, 1, 'ACTIVE', 100, 10, '2026-06-24 01:37:40', '2026-06-24 01:37:40'),
(230, 'DH0858-010', 'NikeCourt Dri-FIT', 'nike-nikecourt-dri-fit-dh0858-010', 6, 5, 1069000.00, NULL, 'Áo thun polo thể thao NikeCourt Dri-FIT được thiết kế với chất liệu Dri-FIT thoáng khí, giúp thấm hút mồ hôi cực tốt và giữ cho bạn luôn khô ráo, dễ chịu trên sân tập cũng như trong các hoạt động hàng ngày. Kiểu dáng polo cổ điển thanh lịch phù hợp cho nhiều dịp khác nhau.', 'Men''s Tennis Polo', 'Polyester & Spandex (Dri-FIT)', 0, 1, 'ACTIVE', 100, 10, '2026-06-24 01:37:40', '2026-06-24 01:37:40'),
(231, 'IF0732-451', 'Nike Sportswear Club', 'nike-nike-sportswear-club-if0732-451', 6, 5, 1579000.00, NULL, 'Áo thun polo thể thao Nike Sportswear Club được thiết kế với chất liệu Dri-FIT thoáng khí, giúp thấm hút mồ hôi cực tốt và giữ cho bạn luôn khô ráo, dễ chịu trên sân tập cũng như trong các hoạt động hàng ngày. Kiểu dáng polo cổ điển thanh lịch phù hợp cho nhiều dịp khác nhau.', 'Men''s Jersey Polo', 'Polyester & Spandex (Dri-FIT)', 1, 1, 'ACTIVE', 100, 10, '2026-06-24 01:37:40', '2026-06-24 01:37:40'),
(232, 'IB0274-663', 'Nike Velocity', 'nike-nike-velocity-ib0274-663', 6, 5, 1479000.00, NULL, 'Áo thun polo thể thao Nike Velocity được thiết kế với chất liệu Dri-FIT thoáng khí, giúp thấm hút mồ hôi cực tốt và giữ cho bạn luôn khô ráo, dễ chịu trên sân tập cũng như trong các hoạt động hàng ngày. Kiểu dáng polo cổ điển thanh lịch phù hợp cho nhiều dịp khác nhau.', 'Men''s Dri-FIT Golf Polo', 'Polyester & Spandex (Dri-FIT)', 0, 1, 'ACTIVE', 100, 10, '2026-06-24 01:37:40', '2026-06-24 01:37:40'),
